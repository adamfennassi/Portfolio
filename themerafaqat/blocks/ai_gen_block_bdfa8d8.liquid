{% doc %}
  @prompt
    Create a custom Shopify section called “Promo 3-Image Split Layout”.
    
    DESKTOP LAYOUT:
    - Full width section
    - Background color: soft dusty blush (#d8c3c1 or similar)
    - Top row: 3 equal-width images displayed side-by-side (33.33% each)
    - Images should have equal spacing between them (20–30px gap)
    - Images must be responsive and maintain aspect ratio
    - No rounded corners
    - No shadows
    
    BOTTOM CONTENT AREA:
    - Positioned below the 3 images
    - Left aligned text
    - Large heading in all caps:
      "MEET ANGEL HOLD STYLING CREAM"
    - Heading font:
      - Modern sans serif
      - Medium letter spacing
      - Font weight 600–700
      - Size approx 28–34px
    - Below heading add paragraph text:
      "Your new hair styling hero for soft, buildable, flexible control. Smooth and sculpt with no crunch, for a hold that keeps up with you all day long."
    - Paragraph font size: 14–16px
    - Muted dark grey color
    
    BUTTON:
    - Text: "SHOP NOW"
    - Outline button style
    - 1px solid dark border
    - Transparent background
    - Padding: 12px 30px
    - Letter spacing increased
    - Hover: invert background to dark and text to white
    
    MOBILE LAYOUT:
    - Stack images vertically (100% width each)
    - Keep spacing between images
    - Text centered on mobile
    - Button centered
    - Reduce heading size appropriately
    - Maintain same background color
    
    SETTINGS:
    - Add image picker for 3 images
    - Add heading text field
    - Add paragraph text field
    - Add button text field
    - Add button link field
    - Make background color customizable
    
    Spacing:
    - Top and bottom padding: 60px desktop, 40px mobile
    
    Design style:
    Minimal, luxury, beauty brand aesthetic.
    Clean typography.
    Soft feminine tones.
    Editorial layout feel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-split-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 60px 0;
  }

  .ai-promo-split-container-{{ ai_gen_id }} {
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-promo-split-images-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    margin-bottom: 50px;
  }

  .ai-promo-split-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-promo-split-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-promo-split-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-promo-split-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-promo-split-content-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    text-align: left;
  }

  .ai-promo-split-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.heading_size }}px;
    text-transform: uppercase;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px 0;
    line-height: 1.2;
  }

  .ai-promo-split-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 30px 0;
    max-width: 600px;
  }

  .ai-promo-split-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 30px;
    background-color: transparent;
    color: {{ block.settings.button_text_color }};
    border: 1px solid {{ block.settings.button_border_color }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-promo-split-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_bg }};
  }

  @media screen and (max-width: 749px) {
    .ai-promo-split-{{ ai_gen_id }} {
      padding: 40px 0;
    }

    .ai-promo-split-images-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 40px;
    }

    .ai-promo-split-content-{{ ai_gen_id }} {
      text-align: center;
      padding: 0 20px;
    }

    .ai-promo-split-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-promo-split-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | minus: 2 }}px;
      max-width: 100%;
    }

    .ai-promo-split-button-{{ ai_gen_id }} {
      display: block;
      text-align: center;
      max-width: 200px;
      margin: 0 auto;
    }
  }
{% endstyle %}

<div class="ai-promo-split-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-split-container-{{ ai_gen_id }}">
    <div class="ai-promo-split-images-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% assign image_key = 'image_' | append: i %}
        {% assign image = block.settings[image_key] %}
        
        <div class="ai-promo-split-image-wrapper-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
            >
          {% else %}
            <div class="ai-promo-split-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <div class="ai-promo-split-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-promo-split-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-promo-split-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-promo-split-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Promo 3-image split",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MEET ANGEL HOLD STYLING CREAM"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Your new hair styling hero for soft, buildable, flexible control. Smooth and sculpt with no crunch, for a hold that keeps up with you all day long."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d8c3c1"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "label": "Heading letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 1.5
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1c1d1d"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#5a5a5a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#1c1d1d"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Button border color",
      "default": "#1c1d1d"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#1c1d1d"
    },
    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Button hover text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Promo 3-image split"
    }
  ]
}
{% endschema %}
