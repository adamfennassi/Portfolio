{% doc %}
  @prompt
    Create a premium “Image with Text” section for a modern feminine fashion/beauty brand.
    
    Layout requirements:
    
    Two-column layout
    
    Large lifestyle image on the left
    
    Text content on the right
    
    Soft beige / warm neutral background behind text area
    
    Clean, minimal, luxury aesthetic
    
    Plenty of white space
    
    Vertically centered content
    
    Content requirements:
    
    Small uppercase headline: ABOUT US
    
    3–4 sentence brand description
    
    Tone: premium, feminine, confident, effortless, community-focused
    
    No emojis
    
    No sales language
    
    Refined, editorial feel similar to luxury lifestyle brands
    
    Button requirements:
    
    Single button below text
    
    Text: OUR STORY (all caps)
    
    Rectangular shape (not fully rounded)
    
    Light neutral background (off-white)
    
    Thin subtle border
    
    Dark gray text
    
    Medium letter spacing
    
    Minimal hover effect (slightly darker background)
    
    Centered under paragraph
    
    Typography:
    
    Elegant serif or modern clean font
    
    Slight letter spacing for headline
    
    Balanced spacing between elements
    
    Overall style:
    High-end, minimal, soft, sophisticated., text on left side not centre
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-text-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 500px;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-text-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-content-wrapper-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    text-align: left;
  }

  .ai-image-text-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    letter-spacing: {{ block.settings.headline_spacing }}px;
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.spacing_headline_to_text }}px 0;
    font-weight: 400;
  }

  .ai-image-text-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: {{ block.settings.description_line_height }};
    margin: 0 0 {{ block.settings.spacing_text_to_button }}px 0;
  }

  .ai-image-text-description-{{ ai_gen_id }} p {
    margin: 0 0 1em 0;
  }

  .ai-image-text-description-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-image-text-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    text-transform: uppercase;
    transition: background-color 0.3s ease;
    font-weight: 400;
  }

  .ai-image-text-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      width: 100%;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      min-height: 400px;
    }

    .ai-image-text-content-wrapper-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-image-text-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-image-text-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-image-text-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-text-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-text-container-{{ ai_gen_id }}">
    <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-text-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-text-image-placeholder-{{ ai_gen_id }}">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
          <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
            Add a lifestyle image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-image-text-content-wrapper-{{ ai_gen_id }}">
      <div class="ai-image-text-content-{{ ai_gen_id }}">
        {% if block.settings.headline != blank %}
          <h2 class="ai-image-text-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-image-text-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-image-text-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
